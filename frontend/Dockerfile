FROM node:20-alpine

WORKDIR /app

# Copy package files if they exist (will be generated by npm create)
COPY package*.json ./

# Try to install dependencies if package.json exists, otherwise skip
RUN if [ -f package.json ]; then npm install; fi

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
